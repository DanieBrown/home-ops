{
  "version": 1,
  "hooks": {
    "sessionStart": [
      {
        "type": "command",
        "bash": "node scripts/hooks/on-prompt.mjs",
        "powershell": "node scripts/hooks/on-prompt.mjs",
        "cwd": ".",
        "timeoutSec": 10
      }
    ],
    "userPromptSubmitted": [
      {
        "type": "command",
        "bash": "node scripts/hooks/on-prompt.mjs",
        "powershell": "node scripts/hooks/on-prompt.mjs",
        "cwd": ".",
        "timeoutSec": 10
      }
    ],
    "preToolUse": [
      {
        "type": "command",
        "bash": "node scripts/hooks/on-pretool.mjs",
        "powershell": "node scripts/hooks/on-pretool.mjs",
        "cwd": ".",
        "timeoutSec": 10
      }
    ],
    "postToolUse": [
      {
        "type": "command",
        "bash": "node scripts/hooks/on-bash.mjs",
        "powershell": "node scripts/hooks/on-bash.mjs",
        "cwd": ".",
        "timeoutSec": 15
      }
    ]
  }
}
