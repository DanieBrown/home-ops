{
  "name": "home-ops",
  "version": "2.0.0",
  "description": "AI-powered home search pipeline built on Claude Code",
  "scripts": {
    "browser:setup": "node scripts/browser/browser-session.mjs configured --caller setup --hosted --channel chrome",
    "browser:setup:edge": "node scripts/browser/browser-session.mjs configured --caller setup --hosted --channel msedge --profile edge-host",
    "browser:review": "node scripts/browser/review-tabs.mjs",
    "browser:status": "node scripts/browser/browser-session.mjs --status --profile chrome-host",
    "browser:session": "node scripts/browser/browser-session.mjs",
    "evaluate:pending": "node scripts/pipeline/evaluate-pending.mjs",
    "audit:research": "node scripts/research/research-coverage-audit.mjs",
    "plan:research": "node scripts/research/research-source-plan.mjs",
    "extract:sentiment": "node scripts/research/sentiment-browser-extract.mjs",
    "lookup:community": "node scripts/research/community-lookup.mjs",
    "prepare:deep": "node scripts/research/deep-research-packet.mjs",
    "check:construction": "node scripts/research/construction-check.mjs",
    "brief:top3": "node scripts/reports/briefing-pdf.mjs",
    "gate:finalists": "node scripts/research/shortlist-finalist-gate.mjs",
    "cache:stats": "node scripts/system/cache-utils.mjs --stats extraction",
    "cache:clear": "node scripts/system/cache-utils.mjs --clear extraction",
    "cache:sentiment:stats": "node scripts/system/cache-utils.mjs --stats sentiment",
    "cache:sentiment:clear": "node scripts/system/cache-utils.mjs --clear sentiment",
    "dashboard": "node scripts/system/run-dashboard.mjs",
    "dashboard:build": "node scripts/system/run-dashboard.mjs --build",
    "reset:data": "node scripts/pipeline/reset-search-state.mjs",
    "scan": "node scripts/pipeline/scan-listings.mjs",
    "portals:generate": "node scripts/config/generate-portals.mjs",
    "doctor": "node scripts/system/doctor.mjs",
    "verify": "node scripts/pipeline/verify-pipeline.mjs",
    "normalize": "node scripts/pipeline/normalize-statuses.mjs",
    "dedup": "node scripts/pipeline/dedup-tracker.mjs",
    "merge": "node scripts/pipeline/merge-tracker.mjs",
    "sync-check": "node scripts/config/profile-sync-check.mjs",
    "profile:wizard": "node tools/profile-wizard/serve.mjs",
    "profile:wizard:once": "node tools/profile-wizard/serve.mjs --once",
    "update:check": "node scripts/system/update-system.mjs check",
    "update": "node scripts/system/update-system.mjs apply",
    "rollback": "node scripts/system/update-system.mjs rollback",
    "liveness": "node scripts/browser/check-liveness.mjs",
    "test": "node scripts/system/test-all.mjs"
  },
  "keywords": [
    "ai",
    "home-search",
    "real-estate",
    "claude-code",
    "automation"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "dependencies": {
    "playwright": "^1.58.1",
    "yaml": "^2.8.3"
  }
}
